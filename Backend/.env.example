PORT=3000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=throttle_lk

# Set to false in production and use migrations instead.
DB_SYNC=true

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Dashboard login (must match frontend admin login)
ADMIN_USERNAME=admin
# Prefer a bcrypt hash (e.g. node -e "require('bcrypt').hash('yourpassword',10).then(console.log)")
ADMIN_PASSWORD_HASH=
# Dev-only fallback if ADMIN_PASSWORD_HASH is empty (do not use in production)
ADMIN_PASSWORD=
