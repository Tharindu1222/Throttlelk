PORT=3000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=throttle_lk

# Set to false in production and use migrations instead.
DB_SYNC=true

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Dashboard login (must match frontend admin login)
ADMIN_USERNAME=admin
# Prefer a bcrypt hash (e.g. node -e "require('bcrypt').hash('yourpassword',10).then(console.log)")
ADMIN_PASSWORD_HASH=
# Plain password for local dev only if ADMIN_PASSWORD_HASH is empty.
# Prefer THROTTLE_ADMIN_PASSWORD: on Windows, a machine/shell ADMIN_PASSWORD="" can block .env ADMIN_PASSWORD (dotenv does not override existing vars).
# Local dev default: username admin, password admin (change before production).
THROTTLE_ADMIN_PASSWORD=admin
# Legacy fallback (may be overridden by an empty machine env var)
ADMIN_PASSWORD=admin

# --- Admin user in MySQL (`users` table) ---
# On first boot when no admin exists, one row is created using the values above:
# ADMIN_USERNAME, ADMIN_PASSWORD_HASH (stored as-is), or else a bcrypt hash of
# THROTTLE_ADMIN_PASSWORD / ADMIN_PASSWORD / default "admin".
# After that, login uses only the database; change the password by updating `password_hash` or deleting the admin row and restarting to re-seed.
